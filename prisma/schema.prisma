generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Schema {
  id          String    @id @default(cuid())
  name        String
  type        String    // "openapi" | "graphql"
  version     String
  title       String
  description String?
  rawContent  String
  parsedData  String    // JSON serialized ParsedSchema
  baseUrl     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  endpoints   Endpoint[]
  scenarios   Scenario[]
}

model Endpoint {
  id          String    @id @default(cuid())
  schemaId    String
  schema      Schema    @relation(fields: [schemaId], references: [id], onDelete: Cascade)
  method      String    // GET, POST, PUT, DELETE, PATCH
  path        String
  operationId String?
  summary     String?
  description String?
  tags        String?   // JSON array
  parameters  String?   // JSON
  requestBody String?   // JSON
  responses   String?   // JSON
  deprecated  Boolean   @default(false)
  createdAt   DateTime  @default(now())
}

model Scenario {
  id          String    @id @default(cuid())
  name        String
  description String?
  schemaId    String
  schema      Schema    @relation(fields: [schemaId], references: [id], onDelete: Cascade)
  steps       ScenarioStep[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ScenarioStep {
  id              String   @id @default(cuid())
  scenarioId      String
  scenario        Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  stepIndex       Int
  method          String
  path            String
  headers         String?  // JSON
  body            String?  // JSON
  expectedStatus  Int      @default(200)
  description     String?
  extractVariables String? // JSON
}

model MockState {
  id          String   @id @default(cuid())
  schemaId    String
  collection  String
  resourceId  String
  data        String   // JSON
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([schemaId, collection, resourceId])
  @@index([schemaId, collection])
}
